-- =============================================================================
-- 04_evaluation.sql
-- =============================================================================
CREATE OR REPLACE TABLE `{{ project_id }}.{{ dataset }}.evaluation_truth_pairs` AS
SELECT
  t1.source AS source_a,
  t1.part_number AS pn_a,
  t2.source AS source_b,
  t2.part_number AS pn_b,
  t1.canonical_part_id
FROM `{{ project_id }}.{{ dataset }}.truth_table` t1
JOIN `{{ project_id }}.{{ dataset }}.truth_table` t2
  ON t1.canonical_part_id = t2.canonical_part_id
  AND (t1.source != t2.source OR t1.part_number != t2.part_number)
  AND CONCAT(t1.source, t1.part_number) < CONCAT(t2.source, t2.part_number);

CREATE OR REPLACE TABLE `{{ project_id }}.{{ dataset }}.evaluation_pipeline_pairs` AS
SELECT DISTINCT
  r.*,
  IF(t.canonical_part_id IS NOT NULL, TRUE, FALSE) AS is_true_match,
  t.canonical_part_id AS truth_match_group
FROM `{{ project_id }}.{{ dataset }}.auto_approved_matches` r
LEFT JOIN `{{ project_id }}.{{ dataset }}.evaluation_truth_pairs` t
  ON r.source_a = t.source_a AND r.pn_a = t.pn_a
  AND r.source_b = t.source_b AND r.pn_b = t.pn_b;

SELECT
  (SELECT COUNT(*) FROM `{{ project_id }}.{{ dataset }}.evaluation_truth_pairs`) AS total_true_pairs,
  (SELECT COUNT(*) FROM `{{ project_id }}.{{ dataset }}.evaluation_pipeline_pairs`) AS total_predicted_pairs,
  (SELECT COUNT(*)
   FROM `{{ project_id }}.{{ dataset }}.evaluation_pipeline_pairs` p
   JOIN `{{ project_id }}.{{ dataset }}.evaluation_truth_pairs` t
   ON p.source_a = t.source_a AND p.pn_a = t.pn_a
   AND p.source_b = t.source_b AND p.pn_b = t.pn_b) AS true_positives,

   SAFE_DIVIDE(
     (SELECT COUNT(*) FROM `{{ project_id }}.{{ dataset }}.evaluation_pipeline_pairs` p JOIN `{{ project_id }}.{{ dataset }}.evaluation_truth_pairs` t ON p.source_a = t.source_a AND p.pn_a = t.pn_a AND p.source_b = t.source_b AND p.pn_b = t.pn_b),
     (SELECT COUNT(*) FROM `{{ project_id }}.{{ dataset }}.evaluation_pipeline_pairs`)
   ) AS precision_score,

   SAFE_DIVIDE(
     (SELECT COUNT(*) FROM `{{ project_id }}.{{ dataset }}.evaluation_pipeline_pairs` p JOIN `{{ project_id }}.{{ dataset }}.evaluation_truth_pairs` t ON p.source_a = t.source_a AND p.pn_a = t.pn_a AND p.source_b = t.source_b AND p.pn_b = t.pn_b),
     (SELECT COUNT(*) FROM `{{ project_id }}.{{ dataset }}.evaluation_truth_pairs`)
   ) AS recall_score;
